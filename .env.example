# Microsoft Graph / Entra app registration (you have these)
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
ALLOWED_DOMAIN=taxconsulting.co.za
# Public HTTPS URL for webhooks (use ngrok in dev: ngrok http 8000)
WEBHOOK_BASE_URL=https://your-ngrok-id.ngrok.app
WEBHOOK_CLIENT_STATE=generate-a-random-string

# Azure Service Bus
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...
SERVICEBUS_QUEUE_NAME=meeting-jobs

# Database (matches docker-compose)
DATABASE_URL=postgresql+asyncpg://meeting:meeting@localhost:5434/meeting_intel

# AI layer
TRANSCRIBER_IMPL=assemblyai
EXTRACTOR_IMPL=anthropic

ANTHROPIC_API_KEY=your-anthropic-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: only needed if EXTRACTOR_IMPL=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Shared mailbox / service account used to send all outbound mail.
# Must have Mail.Send application permission in Entra.
MAIL_SENDER_UPN=noreply@taxconsulting.co.za

# v1: humans approve before any email is sent
AUTO_SEND_EMAIL=false
# Send POPIA processing notice to organizer (and attendees if available) before AI analysis.
POPIA_NOTICE_ENABLED=true
